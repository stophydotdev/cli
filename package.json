{
  "name": "@stophy/cli",
  "version": "1.0.7",
  "description": "The CLI to search YouTube, get transcripts, read comments, and inspect channels",
  "license": "MIT",
  "bin": {
    "stophy": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stophydotdev/cli"
  },
  "homepage": "https://stophy.dev",
  "keywords": [
    "stophy",
    "youtube",
    "youtube-api",
    "youtube-transcript",
    "youtube-comments",
    "youtube-replies",
    "youtube-channel",
    "youtube-playlist",
    "youtube-video",
    "youtube-search",
    "youtube-cli",
    "ai-agents",
    "llm",
    "mcp",
    "transcript",
    "search"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node ./dist/index.js",
    "dev": "tsc --watch",
    "check": "biome check ./src",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "typescript": "^5.8.0"
  }
}
