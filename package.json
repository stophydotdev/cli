{
  "name": "@stophy/cli",
  "version": "1.0.8",
  "description": "YouTube context for AI agents. Search, transcripts, comments, channels, and playlists — structured JSON from the terminal.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "stophy": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://stophy.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stophydotdev/cli.git"
  },
  "bugs": {
    "url": "https://github.com/stophydotdev/cli/issues"
  },
  "keywords": [
    "stophy",
    "youtube",
    "youtube-data",
    "youtube-api",
    "youtube-transcript",
    "youtube-comments",
    "youtube-channel",
    "youtube-playlist",
    "youtube-search",
    "youtube-cli",
    "ai-agent",
    "ai-agents",
    "youtube-for-ai",
    "llm",
    "mcp",
    "transcript",
    "search"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node ./dist/index.js",
    "dev": "tsc --watch",
    "check": "biome check ./src",
    "check-types": "tsc --noEmit",
    "bump:patch": "npm version patch --no-git-tag-version --package-lock=false",
    "bump:minor": "npm version minor --no-git-tag-version --package-lock=false",
    "bump:major": "npm version major --no-git-tag-version --package-lock=false",
    "bump:beta": "npm version prerelease --preid beta --no-git-tag-version --package-lock=false",
    "build:binary": "bash scripts/build-binaries.sh",
    "build:binary:darwin": "bash scripts/build-binaries.sh darwin",
    "build:binary:linux": "bash scripts/build-binaries.sh linux",
    "build:binary:windows": "bash scripts/build-binaries.sh windows"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "conf": "^15.1.0",
    "open": "^11.0.0",
    "ora": "^9.4.1",
    "prompts": "^2.4.2",
    "update-notifier": "^7.3.1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "@types/prompts": "^2.4.9",
    "@types/update-notifier": "^6.0.8",
    "typescript": "^5.8.0"
  }
}
