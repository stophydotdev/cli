{
  "name": "stophy-cli",
  "version": "0.2.1",
  "description": "Search, extract and analyze YouTube from the terminal",
  "license": "MIT",
  "type": "module",
  "bin": {
    "stophy": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stophydotdev/stophy-cli"
  },
  "homepage": "https://stophy.dev",
  "keywords": [
    "youtube",
    "api",
    "cli",
    "transcript",
    "search",
    "video",
    "data"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target node --minify && chmod +x ./dist/index.js",
    "prepare": "bun run build",
    "start": "node ./dist/index.js",
    "dev": "bun run src/index.ts",
    "check": "biome check ./src",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "typescript": "^5.8.0"
  }
}
